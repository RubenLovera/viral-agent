# ─────────────────────────────────────────────────────────────────────────────
# VIRAL Agent — VPS Environment Template
# Copy to /root/culver-os/.env.viral-{yourname} and fill in all values.
# ─────────────────────────────────────────────────────────────────────────────

# ── Telegram ─────────────────────────────────────────────────────────────────
# Create a bot via @BotFather. Get CHAT_ID by sending /start to the bot and
# checking https://api.telegram.org/bot<TOKEN>/getUpdates
VIRAL_TOKEN=        # xxxxxxxxxxx:AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA
CHAT_ID=            # -100XXXXXXXXXX  (negative for group chats)
VIRAL_THREAD_ID=    # Topic ID of the VIRAL thread in your Telegram group (0 if none)

# ── SideShift ────────────────────────────────────────────────────────────────
# Get from app.sideshift.app → Settings → API Keys
SIDESHIFT_API_KEY=
SS_PROGRAM=         # Program ID from app.sideshift.app → Programs

# ── Mac Relay (ngrok tunnel) ─────────────────────────────────────────────────
# The ngrok URL for YOUR Mac (different from every manager).
# Get a free static domain at ngrok.com → Domains → Claim a free static domain
MAC_RELAY_URL=      # https://your-domain.ngrok-free.app
MAC_RELAY_KEY=      # Secret key you set in ~/VIRAL/.env on your Mac (same value)

# ── Gemini ───────────────────────────────────────────────────────────────────
# Get from aistudio.google.com → API Keys
GEMINI_API_KEY=

# ── Slack TVA ────────────────────────────────────────────────────────────────
# Bot token: create a Slack App at api.slack.com → install to your workspace
# User token: needed for reading DMs (xoxp-...)
SLACK_BOT_TOKEN=    # xoxb-...
SLACK_USER_TOKEN=   # xoxp-...
SLACK_CHANNEL_IDS=  # Comma-separated channel/DM IDs: C0B254Z28T1,D0B3P26CUM7

# ── Campaign config ──────────────────────────────────────────────────────────
POSTS_GOAL=60       # Total posts goal for this campaign contract
CLIENT_NAME=        # Your client's brand name (e.g. "SkinQueens", "FitApp")
MANAGER_NAME=       # Your first name (used in outreach messages)

# ── Paths (VPS) ──────────────────────────────────────────────────────────────
# Each manager gets their own data and knowledge directories.
DATA_DIR=/root/culver-os/viral-bot-yourname/data
KNOWLEDGE_DIR=/root/culver-os/viral-bot-yourname/knowledge
BRIEF_FILENAME=campaign_brief.md   # Filename of campaign brief inside KNOWLEDGE_DIR

# ── VPS info (used in monthly voice profile reminder) ────────────────────────
VPS_HOST=           # Your VPS IP address (e.g. 187.127.255.6)
